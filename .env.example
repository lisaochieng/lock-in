# Supabase configuration
# Copy this file to `.env` and fill in the values from your Supabase project
# (Supabase dashboard -> Project Settings -> API).
#
# These must be prefixed with VITE_ so Vite exposes them to the client bundle.

# Your project's REST/Auth URL, e.g. https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Your project's public anon key (safe to use in the browser)
VITE_SUPABASE_ANON_KEY=
